[Unit]
Description=BYD Web Console
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sekkevin
Group=staff
WorkingDirectory=/opt/byd-web-console
EnvironmentFile=/opt/byd-web-console/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/byd-web-console/run.sh
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
